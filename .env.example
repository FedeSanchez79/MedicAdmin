# Ruta a la base de datos de MedicData (medicdata.db)
MEDICDATA_DB_PATH=C:/ruta/al/proyecto/medicdata/database/medicdata.db

# Ruta a la base de datos de MedicProfessionals (medicprofessionals.db)
MEDICPROFESSIONALS_DB_PATH=C:/ruta/al/proyecto/medicprofessionals/database/medicprofessionals.db

# Ruta a la base de datos propia de MedicAdmin (se crea automáticamente)
ADMIN_DB_PATH=./database/medicadmin.db

# Secreto para firmar JWT (cambiar en producción)
JWT_SECRET=cambia_este_secreto_en_produccion_min32chars

# Puerto del servidor (opcional, por defecto Next.js usa 3002)
PORT=3002
